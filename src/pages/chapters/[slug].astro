---
import { getCollection, render } from "astro:content";
import ChapterLayout from "../../layouts/ChapterLayout.astro";

export async function getStaticPaths() {
  const toSlug = (id: string) => id.replace(/\.md$/, "");
  const allChapters = await getCollection("chapters");
  const sorted = allChapters.toSorted((a, b) => a.data.order - b.data.order);

  return sorted.map((chapter, index) => ({
    params: { slug: toSlug(chapter.id) },
    props: {
      chapter,
      prevChapter:
        index > 0
          ? { slug: toSlug(sorted[index - 1].id), title: sorted[index - 1].data.title }
          : null,
      nextChapter:
        index < sorted.length - 1
          ? { slug: toSlug(sorted[index + 1].id), title: sorted[index + 1].data.title }
          : null,
    },
  }));
}

const { chapter, prevChapter, nextChapter } = Astro.props;
const { Content } = await render(chapter);
---

<ChapterLayout
  title={chapter.data.title}
  order={chapter.data.order}
  description={chapter.data.description}
  epigraph={chapter.data.epigraph}
  epigraphAuthor={chapter.data.epigraphAuthor}
  prevChapter={prevChapter}
  nextChapter={nextChapter}
>
  <Content />
</ChapterLayout>
