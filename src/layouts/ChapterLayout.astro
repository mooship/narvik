---
import { Schema } from "astro-seo-schema";
import { config } from "../config";
import Layout from "./Layout.astro";

interface Props {
  title: string;
  order: number;
  description?: string;
  epigraph?: string;
  epigraphAuthor?: string;
  prevChapter?: { slug: string; title: string } | null;
  nextChapter?: { slug: string; title: string } | null;
  bookTitle?: string;
}

const {
  title,
  order,
  description,
  epigraph,
  epigraphAuthor,
  prevChapter,
  nextChapter,
  bookTitle = config.title,
} = Astro.props;

const chapterNumber = String(order).padStart(2, "0");
---

<Layout title={`${title} — ${bookTitle}`} description={description ?? config.description}>
  <Schema
    item={{
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: config.title, item: config.siteUrl },
        {
          "@type": "ListItem",
          position: 2,
          name: title,
          item: `${config.siteUrl}${Astro.url.pathname}`,
        },
      ],
    }}
  />
  <div class="site-wrapper">
    <!-- Top nav -->
    <nav class="chapter-nav top-nav" aria-label="Site navigation">
      <a href="/" class="nav-home">← {bookTitle}</a>
      <span class="nav-chapter-label" aria-hidden="true">Chapter {order}</span>
    </nav>

    <main id="main-content" class="chapter-main">
      <!-- Chapter header -->
      <header class="chapter-header">
        <span class="chapter-number" aria-label={`Chapter ${order}`}>{chapterNumber}</span>
        <h1 class="chapter-title">{title}</h1>
        {
          epigraph && (
            <blockquote class="epigraph">
              <p>{epigraph}</p>
              {epigraphAuthor && <cite>{epigraphAuthor}</cite>}
            </blockquote>
          )
        }
      </header>

      <!-- Body -->
      <article class="prose">
        <slot />
      </article>

      <!-- Chapter footer navigation -->
      <footer class="chapter-footer">
        <div class="chapter-pagination">
          {
            prevChapter ? (
              <a
                href={`/chapters/${prevChapter.slug}`}
                class="page-link page-link--prev"
                aria-label={`Previous chapter: ${prevChapter.title}`}
              >
                <span class="page-link__dir" aria-hidden="true">
                  ← Previous
                </span>
                <span class="page-link__title">{prevChapter.title}</span>
              </a>
            ) : (
              <span />
            )
          }

          <a href="/" class="page-link page-link--toc">Contents</a>

          {
            nextChapter ? (
              <a
                href={`/chapters/${nextChapter.slug}`}
                class="page-link page-link--next"
                aria-label={`Next chapter: ${nextChapter.title}`}
              >
                <span class="page-link__dir" aria-hidden="true">
                  Next →
                </span>
                <span class="page-link__title">{nextChapter.title}</span>
              </a>
            ) : (
              <span />
            )
          }
        </div>
        <p class="site-license">
          Licensed under <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" rel="license"
            >CC BY-NC-SA 4.0</a
          >.
        </p>
      </footer>
    </main>
  </div>
</Layout>

<script
  define:vars={{
    _slug: Astro.url.pathname.replace("/chapters/", ""),
    _title: title,
    _order: order,
  }}
>
  try {
    localStorage.setItem(
      "narvik_lastRead",
      JSON.stringify({ slug: _slug, title: _title, order: _order })
    );
  } catch (_) {}
</script>

<style>
  /* ── Wrapper ─────────────────────────────────────────── */
  .site-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── Top nav ─────────────────────────────────────────── */
  .top-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-md) var(--page-padding);
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .nav-home {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.01em;
  }

  .nav-home:hover {
    color: var(--accent-dark);
    text-decoration: underline;
  }

  .nav-chapter-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* ── Main column ─────────────────────────────────────── */
  .chapter-main {
    flex: 1;
    width: 100%;
    max-width: calc(var(--measure) + (var(--page-padding) * 2));
    margin: 0 auto;
    padding: var(--space-2xl) var(--page-padding) var(--space-3xl);
  }

  /* ── Chapter header ──────────────────────────────────── */
  .chapter-header {
    margin-bottom: var(--space-2xl);
  }

  .chapter-number {
    display: block;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--accent);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: var(--space-sm);
  }

  .chapter-title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 900;
    line-height: 1.1;
    color: var(--text);
    margin-bottom: 0;
  }

  /* ── Footer pagination ───────────────────────────────── */
  .chapter-footer {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--border);
  }

  .site-license {
    margin-top: var(--space-lg);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.06em;
  }

  .chapter-pagination {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-md);
    align-items: start;
  }

  .page-link {
    text-decoration: none;
    color: var(--text-muted);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    padding: var(--space-sm) 0;
    min-height: 44px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (prefers-reduced-motion: no-preference) {
    .page-link {
      transition: color 0.15s ease;
    }
  }

  .page-link:hover {
    color: var(--accent);
  }

  .page-link--next {
    text-align: right;
  }

  .page-link--toc {
    text-align: center;
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    align-self: center;
    align-items: center;
  }

  .page-link__dir {
    display: block;
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 2px;
  }

  .page-link__title {
    display: block;
    font-family: var(--font-serif);
    font-style: italic;
  }

  /* ── Mobile adjustments ──────────────────────────────── */
  @media (max-width: 640px) {
    .chapter-pagination {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
    }

    .page-link--toc {
      grid-column: 1 / -1;
      order: -1;
      border-bottom: 1px solid var(--border);
      padding-bottom: var(--space-md);
      margin-bottom: var(--space-xs);
    }
  }
</style>
